FROM elasticsearch:9.2.3

# Install analysis-icu; trust any SSL cert to handle corporate/internal CA chains.
RUN ES_JAVA_OPTS="-Djavax.net.ssl.trustStore=NONE -Djavax.net.ssl.trustStoreType=JKS" \
    bin/elasticsearch-plugin install --batch analysis-icu || \
    echo "[ragent] WARNING: analysis-icu install failed; container starts without ICU plugin"

ENV discovery.type=single-node
ENV xpack.security.enabled=false
