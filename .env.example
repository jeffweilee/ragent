# =============================================================================
# ragent — Environment Variables
# Usage: cp .env.example .env  →  fill REQUIRED vars  →  start API + worker
# =============================================================================

# -----------------------------------------------------------------------------
# 4.6.1  Bootstrap & HTTP server
# -----------------------------------------------------------------------------
RAGENT_ENV=dev                        # REQUIRED — set before boot (dev|staging|prod)
RAGENT_AUTH_DISABLED=true             # Must be true in P1; removed in P2 to enable JWT
RAGENT_TRUST_X_USER_ID_HEADER=false   # P2 only — bypass JWT and trust X-User-Id header; strictly ignored in prod
RAGENT_PERMISSION_INGEST_ENABLED=false # P2 only — enable PermissionClient gate on GET/DELETE/LIST ingest
RAGENT_PERMISSION_CHAT_ENABLED=false  # P2 only — enable PermissionClient post-filter on chat retrieval
RAGENT_HOST=127.0.0.1                 # API bind address
RAGENT_PORT=8000                      # API bind port
LOG_LEVEL=INFO                        # DEBUG|INFO|WARNING|ERROR

# -----------------------------------------------------------------------------
# 4.6.2  Datastore connections (boot-blocking)
# -----------------------------------------------------------------------------
MARIADB_DSN=                          # REQUIRED — set before boot (mysql+aiomysql://user:pass@host:3306/ragent?charset=utf8mb4)
ES_HOSTS=                             # REQUIRED — set before boot (comma-separated https?://host:port)
ES_USERNAME=                          # basic-auth username; omit for unauthenticated dev
ES_PASSWORD=                          # basic-auth password
ES_API_KEY=                           # alternative to username/password (mutually exclusive)
ES_VERIFY_CERTS=true                  # set false for self-signed dev clusters
MINIO_ENDPOINT=                       # REQUIRED — set before boot (host:port, no scheme)
MINIO_ACCESS_KEY=                     # REQUIRED — set before boot
MINIO_SECRET_KEY=                     # REQUIRED — set before boot
MINIO_SECURE=false                    # true => HTTPS
MINIO_BUCKET=ragent                   # single staging bucket

# -----------------------------------------------------------------------------
# 4.6.3  Redis (B27)
# -----------------------------------------------------------------------------
REDIS_MODE=standalone                 # standalone|sentinel
REDIS_BROKER_URL=redis://localhost:6379/0       # TaskIQ broker URL (mode=standalone)
REDIS_RATELIMIT_URL=redis://localhost:6379/1    # rate-limiter URL (mode=standalone)
REDIS_SENTINEL_HOSTS=                 # REQUIRED — set before boot (if mode=sentinel): comma-separated host:port
REDIS_BROKER_SENTINEL_MASTER=ragent-broker      # master name for broker (mode=sentinel)
REDIS_RATELIMIT_SENTINEL_MASTER=ragent-ratelimit  # master name for rate-limiter (mode=sentinel)

# -----------------------------------------------------------------------------
# 4.6.4  Third-party API endpoints & credentials
# -----------------------------------------------------------------------------
AI_API_AUTH_URL=                      # REQUIRED — set before boot (TokenManager J1->J2 endpoint)
AI_API_CLIENT_ID=                     # REQUIRED — set before boot (never logged, never echoed)
AI_API_CLIENT_SECRET=                 # REQUIRED — set before boot (never logged, never echoed)
EMBEDDING_API_URL=                    # REQUIRED — set before boot (bge-m3 endpoint)
LLM_API_URL=                          # REQUIRED — set before boot (gptoss-120b endpoint)
RERANK_API_URL=                       # REQUIRED — set before boot (rerank endpoint, wired in P2)
HR_API_URL=                           # OpenFGA-related role lookup (P2+, future)

# -----------------------------------------------------------------------------
# 4.6.5  Worker, Reconciler & retry policy
# -----------------------------------------------------------------------------
WORKER_HEARTBEAT_INTERVAL_SECONDS=30  # how often worker refreshes updated_at during pipeline
WORKER_MAX_ATTEMPTS=5                 # pipeline gives up and marks FAILED once attempt > this
PIPELINE_TIMEOUT_SECONDS=1800         # overall pipeline-body wall-clock ceiling (30 min)
RECONCILER_PENDING_STALE_SECONDS=300  # re-dispatch threshold for PENDING rows with aged heartbeat
RECONCILER_UPLOADED_STALE_SECONDS=300 # re-kiq threshold for UPLOADED orphans
RECONCILER_DELETING_STALE_SECONDS=300 # resume threshold for stuck DELETING cascades

# -----------------------------------------------------------------------------
# 4.6.6  Pipeline & chat tunables
# -----------------------------------------------------------------------------
INGEST_MAX_FILE_SIZE_BYTES=52428800   # 50 MB upload cap; 413 on overrun
INGEST_LIST_MAX_LIMIT=100             # GET /ingest?limit= upper bound
CSV_CHUNK_TARGET_CHARS=2000           # RowMerger target merged-buffer size
EMBEDDER_BATCH_SIZE=32                # chunks per embedder HTTP call
CHAT_JOIN_MODE=rrf                    # rrf|concatenate|vector_only|bm25_only
EXCERPT_MAX_CHARS=512                 # SourceHydrator truncation length
RAGENT_DEFAULT_LLM_PROVIDER=openai   # echoed when request omits provider
RAGENT_DEFAULT_LLM_MODEL=gptoss-120b  # echoed when request omits model
RAGENT_DEFAULT_LLM_TEMPERATURE=0.7
RAGENT_DEFAULT_LLM_MAX_TOKENS=4096
RAGENT_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant
CHAT_RATE_LIMIT_PER_MINUTE=30        # per-user request cap on /chat + /chat/stream
CHAT_RATE_LIMIT_WINDOW_SECONDS=60    # fixed-window length for rate limit

# -----------------------------------------------------------------------------
# 4.6.7  Per-call timeouts
# -----------------------------------------------------------------------------
EMBEDDER_INGEST_TIMEOUT_SECONDS=30   # per-batch (32 strings) ingest call
EMBEDDER_QUERY_TIMEOUT_SECONDS=10    # single-string chat-query call
ES_BULK_TIMEOUT_SECONDS=60           # VectorExtractor bulk index/delete
ES_QUERY_TIMEOUT_SECONDS=10          # chat retrievers (vector + BM25)
MINIO_GET_TIMEOUT_SECONDS=30         # worker download from staging
MINIO_PUT_TIMEOUT_SECONDS=60         # router upload to staging
LLM_TIMEOUT_SECONDS=120              # LLMClient.{chat|stream}
PLUGIN_FAN_OUT_TIMEOUT_SECONDS=60    # per-plugin extract/delete ceiling
READYZ_PROBE_TIMEOUT_SECONDS=2       # per-dependency /readyz probe budget

# -----------------------------------------------------------------------------
# 4.6.8  Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=         # OTLP collector URL; absence disables export
OTEL_SERVICE_NAME=ragent-api         # ragent-api|ragent-worker|ragent-reconciler
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1          # sampling ratio (raise to 1.0 in dev)
