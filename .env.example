# Copy to .env and fill in values for local development.

# --- Auth / Token Exchange (J1 credentials) ---
AUTH_URL=http://auth-service/
AUTH_CLIENT_ID=your-client-id
AUTH_CLIENT_SECRET=your-client-secret

# --- AI clients ---
EMBEDDING_API_URL=http://embedding-service/v1/embeddings
LLM_API_URL=http://llm-service/v1/chat/completions
RERANK_API_URL=http://rerank-service/v1/rerank

# --- Datastores ---
MARIADB_DSN=mysql+pymysql://ragent:ragent@localhost:3306/ragent
ES_HOSTS=http://localhost:9200
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Observability (dev-friendly defaults) ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Server ---
RAGENT_HOST=127.0.0.1
RAGENT_PORT=8000
